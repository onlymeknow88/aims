{
    "name": "laravel/laravel",
    "type": "project",
    "description": "The Laravel Framework.",
    "keywords": [
        "framework",
        "laravel"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-gd": "*",
        "ext-zip": "*",
        "awobaz/compoships": "^2.2",
        "barryvdh/laravel-dompdf": "^2.0",
        "bensampo/laravel-enum": "^6.2",
        "composer/semver": "^3.3",
        "filament/filament": "^2.0",
        "guzzlehttp/guzzle": "^7.2",
        "haruncpi/laravel-id-generator": "^1.1",
        "jantinnerezo/livewire-alert": "^2.2",
        "konnco/filament-import": "^1.6",
        "laravel/framework": "^9.19",
        "laravel/sanctum": "^3.0",
        "laravel/socialite": "^5.27",
        "laravel/tinker": "^2.7",
        "laravel/ui": "^4.2",
        "livewire/livewire": "^2.10",
        "maatwebsite/excel": "^3.1",
        "mhmiton/laravel-modules-livewire": "^1.6",
        "mpdf/mpdf": "^8.3",
        "nicolaslopezj/searchable": "^1.13",
        "nwidart/laravel-modules": "9.0.6",
        "phpmailer/phpmailer": "^6.8",
        "phpoffice/phpword": "^1.1",
        "pragmarx/google2fa": "^9.0",
        "psr/simple-cache": "2.0",
        "rappasoft/laravel-livewire-tables": "^2.11",
        "setasign/fpdi-fpdf": "^2.3",
        "simplesoftwareio/simple-qrcode": "^4.2",
        "socialiteproviders/microsoft-azure": "^5.2",
        "spatie/laravel-permission": "^5.7"
    },
    "require-dev": {
        "barryvdh/laravel-ide-helper": "^2.13",
        "doctrine/dbal": "^3.6",
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.0.1",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^6.1",
        "phpunit/phpunit": "^9.5.10",
        "spatie/laravel-ignition": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/",
            "Modules\\": "Modules/"
        },
        "files": [
            "Modules/Mcu/Http/Helper.php",
            "app/Helpers/CsmsHelper.php",
            "app/Helpers/FieldLeadershipHelper.php",
            "app/Helpers/general.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi",
            "@php artisan vendor:publish --force --tag=livewire:assets --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force",
            "@php artisan filament:upgrade"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": [
                "barryvdh/laravel-ide-helper"
            ]
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
